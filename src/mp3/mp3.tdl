module({
  name="MP3",
  copyright="Paul Manias © 2006-2026",
  version=1.0,
  status="stable",
  timestamp=20240611
},
function()
  restrict(function()
    loadFile(glPath .. 'common.tdl')
  end)

  klass('MP3', {
    base = 'Sound',
    src = { 'mp3.cpp' },
    output = 'mp3_def.cpp'
  },
  nil,
  [[
   ~objMP3();
  ]])
end)
