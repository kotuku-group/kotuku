@Test function ResolvePathApproximateAndCanonical()
   test_root = glTempRoot .. 'resolve_path/'
   nested_path = test_root .. 'nested/'
   target_path = test_root .. 'resolve_approx.txt'

   resetPath(test_root)
   ensureFolder(nested_path)
   writeFile(target_path, 'Resolve path content')

   err, exact_path = mSys.ResolvePath(target_path)
   assert(err is ERR_Okay, 'ResolvePath() failed for the exact path: ' .. mSys.GetErrorMsg(err))

   err, approx_path = mSys.ResolvePath('~' .. test_root .. 'resolve_approx')
   assert(err is ERR_Okay, 'ResolvePath() failed for the approximated path: ' .. mSys.GetErrorMsg(err))
   assert(approx_path is exact_path, 'ResolvePath() should resolve approximated paths to the same target.')

   err, flag_approx_path = mSys.ResolvePath(test_root .. 'resolve_approx', RSF_APPROXIMATE)
   assert(err is ERR_Okay, 'ResolvePath() with RSF_APPROXIMATE failed: ' .. mSys.GetErrorMsg(err))
   assert(flag_approx_path is exact_path, 'RSF_APPROXIMATE should resolve to the same canonical path as the exact reference.')

   err, normalised_path = mSys.ResolvePath(test_root .. 'nested/../resolve_approx.txt')
   assert(err is ERR_Okay, 'ResolvePath() failed for a path requiring canonicalisation: ' .. mSys.GetErrorMsg(err))
   assert(normalised_path is exact_path, 'ResolvePath() should canonicalise "." and ".." segments.')
end

----------------------------------------------------------------------------------------------------------------------

@Test function ResolvePathSpecialCases()
   err = mSys.ResolvePath('codex_missing_volume:missing.file')
   assert(err is ERR_Search, 'ResolvePath() should return ERR_Search for an unknown volume, got: ' .. mSys.GetErrorMsg(err))

   err, string_path = mSys.ResolvePath('string:hello world')
   assert(err is ERR_Okay, 'ResolvePath() failed for a string: path: ' .. mSys.GetErrorMsg(err))
   assert(string_path is 'string:hello world', 'ResolvePath() should return string: paths unchanged.')

   err = mSys.ResolvePath(':', RSF_CHECK_VIRTUAL)
   assert(err is ERR_VirtualVolume, 'ResolvePath() with RSF_CHECK_VIRTUAL should report the virtual root, got: ' .. mSys.GetErrorMsg(err))

   err, root_path = mSys.ResolvePath(':')
   assert(err is ERR_Okay, 'ResolvePath() should accept the virtual root path: ' .. mSys.GetErrorMsg(err))
   assert(type(root_path) is 'string', 'ResolvePath() should return a string for the virtual root path.')
end

