@Test function ResolvePathNoFileCheck()
   missing_path = glTempRoot .. 'resolve_path.tmp'
   resetPath(missing_path)

   err = mSys.ResolvePath(missing_path)
   assert(err is ERR_FileNotFound, 'ResolvePath() without RSF_NO_FILE_CHECK should fail for a missing file, got: ' .. mSys.GetErrorMsg(err))

   err, resolved_path = mSys.ResolvePath(missing_path, RSF_NO_FILE_CHECK)
   assert(err is ERR_Okay, 'ResolvePath() with RSF_NO_FILE_CHECK failed: ' .. mSys.GetErrorMsg(err))
   assert(type(resolved_path) is 'string', 'ResolvePath() should return a string result.')
   assert(#resolved_path > 0, 'ResolvePath() returned an empty path string.')
end

