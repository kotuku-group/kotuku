@Test function CompareFilePaths()
   compare_path = glTempRoot .. 'compare_file.tmp'

   resetPath(compare_path)

   writeFile(compare_path, 'Compare me')

   err, resolved_path = mSys.ResolvePath(compare_path)
   assert(err is ERR_Okay, 'ResolvePath() failed for CompareFilePaths() test: ' .. mSys.GetErrorMsg(err))

   err = mSys.CompareFilePaths(compare_path, resolved_path)
   assert(err is ERR_Okay, 'CompareFilePaths() should match equivalent paths, got: ' .. mSys.GetErrorMsg(err))
end

