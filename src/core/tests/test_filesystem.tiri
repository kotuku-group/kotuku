@Test function CopyFile()
   src_path = glTempRoot .. 'copy_source.tmp'
   dest_path = glTempRoot .. 'copy_dest.tmp'
   callback_hits = 0

   resetPath(src_path)
   resetPath(dest_path)

   writeFile(src_path, 'Copied content')

   err = mSys.CopyFile(src_path, dest_path, function(Size, Position, Path, Dest, User, FeedbackID)
      callback_hits++
      return FFR_OKAY
   end)

   assert(err is ERR_Okay, 'CopyFile() failed: ' .. mSys.GetErrorMsg(err))
   assert(callback_hits > 0, 'CopyFile() callback was not invoked.')
   assert(readFile(dest_path) is 'Copied content', 'CopyFile() did not preserve the source file content.')
end

