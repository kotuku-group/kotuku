@Test function MoveFile()
   src_path = glTempRoot .. 'move_source.tmp'
   dest_path = glTempRoot .. 'move_dest.tmp'

   resetPath(src_path)
   resetPath(dest_path)

   writeFile(src_path, 'Moved content')

   err = mSys.MoveFile(src_path, dest_path)
   assert(err is ERR_Okay, 'MoveFile() failed: ' .. mSys.GetErrorMsg(err))

   err = mSys.AnalysePath(src_path)
   assert(err != ERR_Okay, 'MoveFile() should remove the source file.')

   assert(readFile(dest_path) is 'Moved content', 'MoveFile() did not preserve the file content.')
end

