@Test function CreateFolderAndDeleteTree()
   root_path = glTempRoot .. 'create_folder/'
   folder_path = root_path .. 'alpha/beta/'
   child_path = folder_path .. 'child.txt'

   resetPath(root_path)

   err = mSys.CreateFolder(folder_path, 0)
   assert(err is ERR_Okay, 'CreateFolder() failed: ' .. mSys.GetErrorMsg(err))

   err = mSys.CreateFolder(folder_path, 0)
   assert(err is ERR_FileExists, 'CreateFolder() should report ERR_FileExists for an existing folder, got: ' .. mSys.GetErrorMsg(err))

   local err, type = mSys.AnalysePath(folder_path)
   assert(err is ERR_Okay, 'AnalysePath() failed for created folder: ' .. mSys.GetErrorMsg(err))
   assert(type is LOC_FOLDER, 'AnalysePath() returned type ' .. type .. ' and not LOC_FOLDER')

   writeFile(child_path, 'Nested content')

   err = mSys.DeleteFile(root_path)
   assert(err is ERR_Okay, 'DeleteFile() failed to remove a folder tree: ' .. mSys.GetErrorMsg(err))

   err = mSys.AnalysePath(root_path)
   assert(err != ERR_Okay, 'Folder tree should no longer exist after DeleteFile().')
end

