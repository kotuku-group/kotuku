@Test function TaskQueryExecutableMetadata()
   local fixture_root = 'temp:task_query_tests/'
   mSys.DeleteFile(fixture_root)
   local err = mSys.CreateFolder(fixture_root, 0)
   assert((err is ERR_Okay) or (err is ERR_FileExists), 'CreateFolder() failed: ' .. mSys.GetErrorMsg(err))

   local fixture_path = fixture_root .. 'task_query_fixture.exe'
   local invalid_path = fixture_root .. 'task_query_invalid.exe'

   writeTaskQueryFixture(fixture_path)

   local task = obj.new('task', { src=fixture_path })
   check task.acSetKey('CustomKey', 'keep')
   check task.acSetKey('ProductName', 'old')
   check task.acQuery()

   local err, value = task.acGetKey('ProductName')
   assert(err is ERR_Okay, 'ProductName was not stored: ' .. mSys.GetErrorMsg(err))
   assert(value is 'Task Query Product', 'Unexpected ProductName: ' .. tostring(value))
   assert(task.name is 'Task Query Product', 'Task.Name was not updated from metadata.')

   err, value = task.acGetKey('FileDescription')
   assert(err is ERR_Okay, 'FileDescription was not stored: ' .. mSys.GetErrorMsg(err))
   assert(value is 'Origo Launcher', 'Unexpected FileDescription: ' .. tostring(value))

   err, value = task.acGetKey('LegalCopyright')
   assert(err is ERR_Okay, 'LegalCopyright was not stored: ' .. mSys.GetErrorMsg(err))
   assert(value is 'Copyright (C) 2026 Paul Manias', 'Unexpected LegalCopyright: ' .. tostring(value))

   err, value = task.acGetKey('CompanyName')
   assert(err is ERR_Okay, 'CompanyName was not stored: ' .. mSys.GetErrorMsg(err))
   assert(value is 'Kotuku Test Company', 'Unexpected CompanyName: ' .. tostring(value))

   err, value = task.acGetKey('FileVersion')
   assert(err is ERR_Okay, 'FileVersion was not stored: ' .. mSys.GetErrorMsg(err))
   assert(value is '9.8.7.6', 'String FileVersion should not be replaced by fixed version data.')

   err, value = task.acGetKey('FixedFileVersion')
   assert(err is ERR_Okay, 'FixedFileVersion was not stored: ' .. mSys.GetErrorMsg(err))
   assert(value is '1.2.3.4', 'Unexpected FixedFileVersion: ' .. tostring(value))

   err, value = task.acGetKey('CustomKey')
   assert(err is ERR_Okay, 'CustomKey was removed: ' .. mSys.GetErrorMsg(err))
   assert(value is 'keep', 'CustomKey was not preserved.')

   local empty_task = obj.new('task')
   err = empty_task.acQuery()
   assert(err is ERR_MissingPath, 'Expected missing Location to return MissingPath, got ' .. mSys.GetErrorMsg(err))

   mSys.DeleteFile(invalid_path)
   local invalid_file = obj.new('file', { src=invalid_path, flags=FL_NEW|FL_WRITE })
   check invalid_file.acWrite('not a PE file')
   invalid_file = nil
   processing.collect()

   local invalid_task = obj.new('task', { src=invalid_path })
   err = invalid_task.acQuery()
   assert(err is ERR_Query, 'Expected non-PE file to return Query, got ' .. mSys.GetErrorMsg(err))

   mSys.DeleteFile(fixture_root)
end

