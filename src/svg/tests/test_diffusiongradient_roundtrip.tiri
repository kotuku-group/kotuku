-- $TIRI

   include 'svg'
   include 'vector'

local glSVGFolder
local glFiles = array<string>

@BeforeAll function setup(State: table)
   glSVGFolder = State.folder
end

@AfterAll function removeFiles()
   for path in values(glFiles) do
      mSys.DeleteFile(path)
   end
end

----------------------------------------------------------------------------------------------------------------------

function absValue(Value: num): num
   if Value < 0 then return -Value end
   return Value
end

function assertNear(Actual: num, Expected: num, Message: str)
   assert(absValue(Actual - Expected) < 0.001, Message .. ' expected ' .. Expected .. ', got ' .. Actual)
end

-- Compare a colour channel against an expected value, tolerating 8-bit quantisation and float storage.

function assertChannel(Actual: num, Expected: num, Message: str)
   assert(absValue(Actual - Expected) < 0.01, Message .. ' expected ' .. Expected .. ', got ' .. Actual)
end

function diffusionDocument(): str
   return [[
<?xml version="1.0" standalone="no"?>
<svg width="120" height="120" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <diffusionGradient id="dg" gradientUnits="userSpaceOnUse">
      <curve d="M 10,10 C 30,5 60,5 90,10"
             left-start="#ff0000" left-end="#ff8000"
             right-start="#0000ff" right-end="#000080"/>
      <curve d="M 10,90 L 90,90" left-start="#00ff00"/>
    </diffusionGradient>
  </defs>
  <rect x="0" y="0" width="100" height="100" fill="url(#dg)"/>
</svg>
]]
end

function malformedDocument(PathValue: str): str
   return [[
<?xml version="1.0" standalone="no"?>
<svg width="120" height="120" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <diffusionGradient id="dg" gradientUnits="userSpaceOnUse">
      <curve d="]] .. PathValue .. [[" left-start="#ff0000" right-start="#0000ff"/>
    </diffusionGradient>
  </defs>
  <rect x="0" y="0" width="100" height="100" fill="url(#dg)"/>
</svg>
]]
end

function malformedInheritedDocument(): str
   return [[
<?xml version="1.0" standalone="no"?>
<svg width="120" height="120" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <diffusionGradient id="base">
      <curve d="M 50,0 L 50,100" left-start="#ff0000" right-start="#0000ff"/>
    </diffusionGradient>
    <diffusionGradient id="dg" href="#base">
      <curve d="M 10,10 Q 20,20 30,30" left-start="#00ff00" right-start="#ff00ff"/>
    </diffusionGradient>
  </defs>
  <rect x="0" y="0" width="100" height="100" fill="url(#dg)"/>
</svg>
]]
end

function invalidColourDocument(): str
   return [[
<?xml version="1.0" standalone="no"?>
<svg width="120" height="120" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <diffusionGradient id="dg">
      <curve d="M 50,0 L 50,100" left-start="not-a-colour" right-start="#0000ff"/>
    </diffusionGradient>
  </defs>
  <rect x="0" y="0" width="100" height="100" fill="url(#dg)"/>
</svg>
]]
end

function loadDiffusion(Path: str):<obj, obj>
   local scene = obj.new('VectorScene', { pageWidth=120, pageHeight=120 })
   local viewport = scene.new('VectorViewport', { x=0, y=0, width='100%', height='100%' })
   local svg = obj.new('svg', { target=scene, path=Path })
   local err, gradient = scene.mtFindDef('dg')

   assert(err is ERR_Okay, 'Expected dg definition to be parsed')
   return scene, gradient
end

function saveScene(Scene: obj, Path: str): str
   local svg = obj.new('svg', { target=Scene })
   local file = obj.new('file', { path=Path, flags=FL_NEW|FL_WRITE })
   glFiles:push(Path)
   check svg.acSaveToObject(file, 0)
   file = nil
   return io.readAll(Path)
end

function assertCurvesMatch(Actual: obj, Expected: obj, Label: str)
   local actual_curves = Actual.curves
   local expected_curves = Expected.curves
   assert(#actual_curves is #expected_curves, Label .. ' should preserve the curve count')

   local coords = { 'startX', 'startY', 'x1', 'y1', 'x2', 'y2', 'endX', 'endY' }
   local colours = { 'leftStart', 'leftEnd', 'rightStart', 'rightEnd' }
   local channels = { 'red', 'green', 'blue', 'alpha' }

   for i=0, #expected_curves - 1 do
      for c=0, #coords - 1 do
         local field = coords[c]
         assertNear(actual_curves[i].curve[field], expected_curves[i].curve[field],
            Label .. '.curve' .. i .. '.' .. field)
      end
      for c=0, #colours - 1 do
         local side = colours[c]
         for ch=0, #channels - 1 do
            local channel = channels[ch]
            assertChannel(actual_curves[i][side][channel], expected_curves[i][side][channel],
               Label .. '.curve' .. i .. '.' .. side .. '.' .. channel)
         end
      end
   end
end

----------------------------------------------------------------------------------------------------------------------

@Test function ParserBuildsCurveRecords()
   local path = 'temp:diffusiongradient_parse.svg'
   io.writeAll(path, diffusionDocument())
   glFiles:push(path)

   local scene, gradient = loadDiffusion(path)
   local curves = gradient.curves
   assert(#curves is 2, 'Expected two curve records')
   assert(gradient.units is VUNIT_USERSPACE, 'gradientUnits should map to user-space units')

   local first = curves[0]
   assertNear(first.curve.startX, 10, 'curve start x')
   assertNear(first.curve.startY, 10, 'curve start y')
   assertNear(first.curve.x1, 30, 'curve control 1 x')
   assertNear(first.curve.y1, 5, 'curve control 1 y')
   assertNear(first.curve.endX, 90, 'curve end x')
   assertNear(first.curve.endY, 10, 'curve end y')

   assertChannel(first.leftStart.red, 1.0, 'left-start red')
   assertChannel(first.leftEnd.green, 128 / 255, 'left-end green')
   assertChannel(first.rightStart.blue, 1.0, 'right-start blue')
   assertChannel(first.rightEnd.blue, 128 / 255, 'right-end blue')

   -- The second curve is an 'L' segment: control points interpolate the straight line, and its missing end
   -- colours inherit the start colours.

   local second = curves[1]
   assertNear(second.curve.x1, 10 + (80 / 3.0), 'straight-line control 1 x')
   assertNear(second.curve.endX, 90, 'straight-line end x')
   assertChannel(second.leftEnd.green, 1.0, 'left-end should inherit left-start')
   assertChannel(second.rightStart.red, 0, 'missing right-start defaults to black')
   assertChannel(second.rightStart.alpha, 1.0, 'missing right-start defaults to opaque')
end

@Test function SaveRoundTripsCurves()
   local path = 'temp:diffusiongradient_roundtrip.svg'
   io.writeAll(path, diffusionDocument())
   glFiles:push(path)

   local scene, gradient = loadDiffusion(path)
   local output_path = 'temp:diffusiongradient_saved.svg'
   local saved = saveScene(scene, output_path)

   assert(string.find(saved, '<diffusionGradient', 0, true) != nil, 'Saved SVG should contain a diffusionGradient element')
   assert(string.find(saved, 'left-start=', 0, true) != nil, 'Saved curves should carry left-start colours')

   local reparsed_scene, reparsed_gradient = loadDiffusion(output_path)
   assertCurvesMatch(reparsed_gradient, gradient, 'round-trip')
   assert(reparsed_gradient.units is VUNIT_USERSPACE, 'Units should survive the round-trip')
end

@Test function FixtureParsesAndRoundTrips()
   -- The on-disk fixture exercises the wider attribute surface: gradientTransform, linearRGB interpolation,
   -- 'C' and 'L' curve segments, hex and rgb() colour syntaxes, alpha components and defaulted colours.

   local scene, gradient = loadDiffusion(glSVGFolder .. 'gradients/diffusiongradient.svg')
   local curves = gradient.curves
   assert(#curves is 3, 'Fixture should produce three curve records')
   assert(gradient.units is VUNIT_USERSPACE, 'Fixture should use user-space units')
   assert(gradient.colourSpace is VCS_LINEAR_RGB, 'color-interpolation should map to linearRGB')

   assertNear(curves[0].curve.x1, 45, 'first curve control 1 x')
   assertChannel(curves[0].rightEnd.blue, 128 / 255, 'rgb() right-end blue')
   assertChannel(curves[1].leftStart.alpha, 0.5, 'rgb() alpha component')
   assertChannel(curves[1].rightEnd.green, 1.0, 'missing right-end inherits right-start')
   assertChannel(curves[2].leftEnd.red, 1.0, 'missing left-end inherits left-start')
   assertChannel(curves[2].rightStart.red, 0, 'missing right-start defaults to black')
   assertChannel(curves[2].rightStart.alpha, 1.0, 'missing right-start defaults to opaque')

   local output_path = 'temp:diffusiongradient_fixture_saved.svg'
   local saved = saveScene(scene, output_path)
   assert(string.find(saved, 'gradientTransform=', 0, true) != nil, 'Saved fixture should preserve the gradient transform')

   local reparsed_scene, reparsed_gradient = loadDiffusion(output_path)
   assertCurvesMatch(reparsed_gradient, gradient, 'fixture round-trip')
   assert(reparsed_gradient.colourSpace is VCS_LINEAR_RGB, 'Colour space should survive the round-trip')
end

@Test function MalformedCurvesDiscardGradient()
   local cases = { 'Q 10 0 20 0', 'M 10,10 C 1 2 3 4', 'M 10,10', 'C 1 2 3 4 5 6', 'M 10,10 L 20,20 L 30,30' }
   for i=0, #cases - 1 do
      local path = f"temp:diffusiongradient_malformed_{i}.svg"
      io.writeAll(path, malformedDocument(cases[i]))
      glFiles:push(path)

      local scene, gradient = loadDiffusion(path)
      assert(#gradient.curves is 0, f"Malformed curve path '{cases[i]}' should discard the gradient")
   end
end

@Test function MalformedCurveClearsInheritedCurves()
   local path = 'temp:diffusiongradient_malformed_inherited.svg'
   io.writeAll(path, malformedInheritedDocument())
   glFiles:push(path)

   local scene, gradient = loadDiffusion(path)
   assert(#gradient.curves is 0, 'A malformed local curve should clear curves inherited through href')
end

@Test function InvalidColourUsesDefault()
   local path = 'temp:diffusiongradient_invalid_colour.svg'
   io.writeAll(path, invalidColourDocument())
   glFiles:push(path)

   local scene, gradient = loadDiffusion(path)
   local colour = gradient.curves[0].leftStart
   assertChannel(colour.red, 0, 'Invalid left-start red should default to black')
   assertChannel(colour.green, 0, 'Invalid left-start green should default to black')
   assertChannel(colour.blue, 0, 'Invalid left-start blue should default to black')
   assertChannel(colour.alpha, 1, 'Invalid left-start alpha should default to opaque')
end
