-- $TIRI

   include 'svg'
   include 'vector'

function saveScene(Scene:obj, Path:str):str
   local svg = obj.new('svg', { target=Scene })
   local file = obj.new('file', { path=Path, flags='!NEW|WRITE' })

   check svg.acSaveToObject(file, 0)
   file = nil
   return io.readAll(Path)
end

function assertContains(Haystack:str, Needle:str, Message:str)
   assert(string.find(Haystack, Needle, 0, true) != nil, Message)
end

function transitionStop(Offset:num, Transform:str)
   local stop = struct.new('Transition')
   stop.offset = Offset
   stop.transform = Transform
   return stop
end

function transitionStops()
   return {
      transitionStop(0.0, 'translate(5 6)'),
      transitionStop(1.0, 'scale(2)')
   }
end

@Test function SavesClipDefWithMapKeyId()
   local scene = obj.new('VectorScene', { pageWidth=100, pageHeight=100 })
   local viewport = scene.new('VectorViewport', { x=0, y=0, width='100%', height='100%' })
   local clip = scene.new('VectorClip', { units=VUNIT_BOUNDING_BOX })

   clip.viewport.new('VectorRectangle', { x=0, y=0, width=1, height=1 })
   viewport.new('VectorRectangle', { x=0, y=0, width=100, height=100, mask=clip })
   check scene.mtAddDef('tile_clip', clip)

   local saved = saveScene(scene, 'temp:svg_defs_clip.svg')
   assertContains(saved, '<clipPath', 'Saved SVG should contain the clipPath definition')
   assertContains(saved, 'id="tile_clip"', 'ClipPath should use the scene def key when SID is empty')
   assertContains(saved, 'clipPathUnits="objectBoundingBox"', 'ClipPath should preserve object-bounding-box units')
   assertContains(saved, '<rect', 'ClipPath should include its viewport child vectors')
end

@Test function SavesPatternDefWithChildren()
   local scene = obj.new('VectorScene', { pageWidth=100, pageHeight=100 })
   local viewport = scene.new('VectorViewport', { x=0, y=0, width='100%', height='100%' })
   local pattern = scene.new('VectorPattern', {
      x=2, y=3, width=8, height=9, units=VUNIT_USERSPACE, contentUnits=VUNIT_BOUNDING_BOX,
      transform='translate(1 2)'
   })

   pattern.viewport.new('VectorRectangle', { x=0, y=0, width=8, height=9, fill='rgb(255,0,0)' })
   check scene.mtAddDef('tile_pattern', pattern)
   viewport.new('VectorRectangle', { x=0, y=0, width=100, height=100, fill='url(#tile_pattern)' })

   local saved = saveScene(scene, 'temp:svg_defs_pattern.svg')
   assertContains(saved, '<pattern', 'Saved SVG should contain the pattern definition')
   assertContains(saved, 'id="tile_pattern"', 'Pattern should use the scene def key')
   assertContains(saved, 'patternUnits="userSpaceOnUse"', 'Pattern should preserve user-space units')
   assertContains(saved, 'patternContentUnits="objectBoundingBox"', 'Pattern should preserve content units')
   assertContains(saved, 'patternTransform=', 'Pattern should preserve transforms')
   assertContains(saved, '<rect', 'Pattern should include its viewport child vectors')
end

@Test function SavesGenericVectorDefWithMapKeyId()
   local scene = obj.new('VectorScene', { pageWidth=100, pageHeight=100 })
   local viewport = scene.new('VectorViewport', { x=0, y=0, width='100%', height='100%' })
   local group = viewport.new('VectorGroup')

   group.new('VectorRectangle', { x=5, y=6, width=7, height=8 })
   check scene.mtAddDef('shared_group', group)

   local saved = saveScene(scene, 'temp:svg_defs_group.svg')
   assertContains(saved, '<g', 'Saved SVG should contain the generic vector definition')
   assertContains(saved, 'id="shared_group"', 'Generic vector defs should use the scene def key when SID is empty')
   assertContains(saved, '<rect', 'Generic vector defs should preserve child vectors')
end

@Test function SavesTransitionDefFromXMLDef()
   local scene = obj.new('VectorScene', { pageWidth=100, pageHeight=100 })
   scene.new('VectorViewport', { x=0, y=0, width='100%', height='100%' })
   local transition = scene.new('VectorTransition', { stops=transitionStops() })

   assertContains(transition.xmlDef, '<stop offset="0"', 'Transition XMLDef should include the first stop')
   assertContains(transition.xmlDef, 'transform="matrix(', 'Transition XMLDef should serialise parsed transforms')

   check scene.mtAddDef('text_transition', transition)

   local saved = saveScene(scene, 'temp:svg_defs_transition.svg')
   assertContains(saved, '<kotuku:transition', 'Saved SVG should contain the transition definition')
   assertContains(saved, 'id="text_transition"', 'Transition should use the scene def key')
   assertContains(saved, '<stop offset="0"', 'Transition definition should include XMLDef stop elements')
   assertContains(saved, 'transform="matrix(', 'Transition definition should include XMLDef transform matrices')
end
