<?xml version="1.0"?>
<!DOCTYPE rpl PUBLIC "-//ROCKLYTE//DTD RPL 1.0//EN">

<info>
 <title>XQuery Stage 4 Tests</title>
 <author>Paul Manias</author>
 <keywords>xquery, test, stage4</keywords>
 <description>Stage 4 XQuery tests for XQuery-only conditionals, object existence helpers and migrated runtime scope usage.</description>
</info>

<body face="Noto Sans" font-size="10pt"/>

<page name="Stage4">

<p>XQuery Stage 4</p>

<if test="1 lt 2">
  <p>IF-TEST-TRUE</p>
</if>
<else>
  <p>IF-TEST-FAIL</p>
</else>

<if test="1 gt 2">
  <p>ELSEIF-FAIL-1</p>
</if>
<elseif test="not(false())">
  <p>ELSEIF-TEST-TRUE</p>
</elseif>
<else>
  <p>ELSEIF-FAIL-2</p>
</else>

<if test="kt-object-exists('stage4document')">
  <p>OBJECT-EXISTS-TRUE</p>
</if>

<if test="not(kt-object-exists('MissingObject'))">
  <p>OBJECT-EXISTS-FALSE</p>
</if>

<repeat count="3">
  <p><print value="REPEAT {$loop?index}"/></p>
</repeat>

<while test="$loop?index lt 3">
  <p><print value="WHILE {$loop?index}"/></p>
</while>

<p><font face="courier" fill="red" style="italic" size="20"><print value="STYLE {$style?font-style} {$style?font-face} {$style?font-size} {$style?font-fill}"/></font></p>
<p><print value="PAGE {$meta?current-page}"/></p>
<p><print value="LAYOUT {$layout?view-width} x {$layout?view-height}"/></p>
<p><print value="LINE {$meta?line-no}"/></p>

</page>
