   local trace_found = false
   for trace_no = 1, 20 do
      local info = jit.util.traceInfo(trace_no)
      if info != nil then
         trace_found = true
         break
      end
   end

   assert(trace_found is true, "Expected array.resize() to produce a JIT trace")
end

