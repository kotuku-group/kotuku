@Test function StringFieldAssignments()
   MAKESTRUCT('StringFieldAssignments', 'zsName,sBorrowed')

   local container = struct.new('StringFieldAssignments', { name='initial' })
   assert(container.name is 'initial', 'struct.new() should initialise an owned C++ string field')

   container.name = 'updated'
   assert(container.name is 'updated', 'Direct assignment should update an owned C++ string field')

   try
      container.borrowed = 'unsupported'
   success
      error('Assigning a raw C string field should fail')
   end
end

