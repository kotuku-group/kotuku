@Test function ObjectFieldAssignments()
   MAKESTRUCT('ObjectFieldAssignments', 'oValue')

   local value = mSys.FindClass('task':hash(), 0)
   local container = struct.new('ObjectFieldAssignments', { value=value })
   local initial_value = container.value
   assert(type(initial_value) is 'object', 'struct.new() should return a native object from an object field')
   assert(initial_value.id is value.id, 'struct.new() should preserve the assigned native object ID')

   container.value = nil
   assert(container.value is nil, 'Assigning nil should clear an object field')

   container.value = value
   local updated_value = container.value
   assert(updated_value.id is value.id, 'Direct assignment should preserve the assigned native object ID')

   local dead_value = obj.new('time')
   dead_value.free()
   try
      container.value = dead_value
   success
      error('Assigning a detached object wrapper should fail')
   end
   container.value = nil
end

