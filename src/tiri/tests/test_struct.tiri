
-----------------------------------------------------------------------------------------------------------------------
-- Retrieve a known struct from a function and test the field values.

@Test(hotpath=true)
function ProbeStruct()
   local meta = mSys.FindClass('task':hash(), 0)
   local err, field = meta.mtFindField('args':hash())
   assert(type(field) is 'table', 'Failed to find args field in task class')
   assert(field.name is 'Args', 'Expected string type for field name')
   assert(field.fieldID > 0, 'Expected fieldID to be greater than zero')
   assert(field.index > 0, 'Expected field index to be greater than zero')
   assert(type(field.writeValue) is 'userdata', 'Expected writeValue to be a function pointer')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function EmbeddedStructArrayStride()
   MAKESTRUCT('TinyStrideColour', 'bRed,bGreen,bBlue,bAlpha')
   MAKESTRUCT('TinyStridePalette', 'eCol:TinyStrideColour[2],lMarker')

   palette = struct.new('TinyStridePalette', { marker=77 })
   colours = palette.Col

   assert(#colours is 2, 'Expected the embedded struct array to expose two elements, got ' .. #colours)
   assert(colours[1].red is 0,
      'Embedded struct array access used the padded serial stride instead of the in-memory stride.')
end

@Test function OffsetZeroEmbeddedStructUsesOwnTable()
   MAKESTRUCT('OffsetZeroChild', 'lValue')
   MAKESTRUCT('OffsetZeroRecord', 'eChild:OffsetZeroChild,lMarker')
   MAKESTRUCT('OffsetZeroWrapper', 'eRecord:OffsetZeroRecord[1]')

   local wrapper = struct.new('OffsetZeroWrapper')
   local patch_record = wrapper.record[0]

   assert(patch_record.child != patch_record, 'Offset-zero embedded struct should not alias its parent table')
   assert(patch_record.child.value is 0, 'Offset-zero embedded struct fields should be readable')
end
