
-----------------------------------------------------------------------------------------------------------------------
-- Retrieve a known struct from a function and test the field values.

@Test(hotpath=true)
function ProbeStruct()
   local meta = mSys.FindClass('task':hash(), 0)
   local err, field = meta.mtFindField('args':hash())
   assert(type(field) is 'table', 'Failed to find args field in task class')
   assert(field.name is 'Args', 'Expected string type for field name')
   assert(field.fieldID > 0, 'Expected fieldID to be greater than zero')
   assert(field.index > 0, 'Expected field index to be greater than zero')
   assert(type(field.writeValue) is 'userdata', 'Expected writeValue to be a function pointer')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function EmbeddedStructArrayStride()
   MAKESTRUCT('TinyStrideColour', 'bRed,bGreen,bBlue,bAlpha')
   MAKESTRUCT('TinyStridePalette', 'eCol:TinyStrideColour[2],lMarker')

   palette = struct.new('TinyStridePalette', { marker=77 })
   assert(type(palette) is 'struct', 'Expected struct.new() to return the native struct type')
   assert(#palette is 2, 'Expected the structure to report its field count')
   assert(palette.structSize() > 0, 'Expected the structure to report its byte size')
   colours = palette.Col

   assert(#colours is 2, 'Expected the embedded struct array to expose two elements, got ' .. #colours)
   assert(colours[1].red is 0,
      'Embedded struct array access used the padded serial stride instead of the in-memory stride.')
end

@Test function OffsetZeroEmbeddedStructUsesOwnTable()
   MAKESTRUCT('OffsetZeroChild', 'lValue')
   MAKESTRUCT('OffsetZeroRecord', 'eChild:OffsetZeroChild,lMarker')
   MAKESTRUCT('OffsetZeroWrapper', 'eRecord:OffsetZeroRecord[1]')

   local wrapper = struct.new('OffsetZeroWrapper')
   local patch_record = wrapper.record[0]

   assert(patch_record.child != patch_record, 'Offset-zero embedded struct should not alias its parent table')
   assert(patch_record.child.value is 0, 'Offset-zero embedded struct fields should be readable')
end

-----------------------------------------------------------------------------------------------------------------------

@Test function ObjectFieldAssignments()
   MAKESTRUCT('ObjectFieldAssignments', 'oValue')

   local value = mSys.FindClass('task':hash(), 0)
   local container = struct.new('ObjectFieldAssignments', { value=value })
   local initial_value = container.value
   assert(type(initial_value) is 'object', 'struct.new() should return a native object from an object field')
   assert(initial_value.id is value.id, 'struct.new() should preserve the assigned native object ID')

   container.value = nil
   assert(container.value is nil, 'Assigning nil should clear an object field')

   container.value = value
   local updated_value = container.value
   assert(updated_value.id is value.id, 'Direct assignment should preserve the assigned native object ID')

   local dead_value = obj.new('time')
   dead_value.free()
   try
      container.value = dead_value
   success
      error('Assigning a detached object wrapper should fail')
   end
   container.value = nil
end

-----------------------------------------------------------------------------------------------------------------------

@Test function StringFieldAssignments()
   MAKESTRUCT('StringFieldAssignments', 'zsName,sBorrowed')

   local container = struct.new('StringFieldAssignments', { name='initial' })
   assert(container.name is 'initial', 'struct.new() should initialise an owned C++ string field')

   container.name = 'updated'
   assert(container.name is 'updated', 'Direct assignment should update an owned C++ string field')

   try
      container.borrowed = 'unsupported'
   success
      error('Assigning a raw C string field should fail')
   end
end

-----------------------------------------------------------------------------------------------------------------------

@Test function UnsupportedFieldAssignmentRaises()
   MAKESTRUCT('UnsupportedFieldAssignment', 'rCallback')
   local container = struct.new('UnsupportedFieldAssignment')

   try
      container.callback = nil
   success
      error('Assigning an unsupported field type should fail')
   end
end

