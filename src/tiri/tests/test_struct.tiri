@Test function NativeStructDeclarationLayoutParity()
   MAKESTRUCT('LegacyDeclaredChild', 'lValue')
   MAKESTRUCT('LegacyDeclaredLayout',
      'bBool,cChar,ubByte,bInt8,ubUInt8,wInt16,uwUInt16,lInt,ulUInt,lInt32,ulUInt32,' ..
      'xInt64,uxUInt64,fFloat,dDouble,zsString,sCStr,pPointer,pIntPointer,pIntList[0],oObject,rCallback,' ..
      'cBuffer[7],lFixed[3],' ..
      'eChild:LegacyDeclaredChild,pChildPointer:LegacyDeclaredChild')
   assert(struct.size('DeclaredLayout') is struct.size('LegacyDeclaredLayout'),
      'Declarative and MAKESTRUCT layouts should have identical byte sizes')
end

